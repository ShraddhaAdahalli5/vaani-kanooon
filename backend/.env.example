# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud Translation API (Optional - for better translations)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Backend Configuration
API_HOST=0.0.0.0
API_PORT=10000
DEBUG=false

# Render Configuration
PORT=10000

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_DIR=uploads

# OCR Configuration
TESSERACT_CMD=/usr/local/bin/tesseract  # Mac/Linux
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe  # Windows

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://vani-kanoon.vercel.app,https://vani-kanoon.onrender.com,https://vani-kanoon.netlify.app
